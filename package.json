    "pages:build": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mercadopago/sdk-react": "^1.0.7",
