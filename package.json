  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "images:migrate:dry": "node scripts/optimize-existing-product-images.cjs --dry-run",
    "images:migrate:run": "node scripts/optimize-existing-product-images.cjs --execute",
    "backfill:orders:addresses:dry": "node --env-file=.env.local scripts/backfill-order-addresses.cjs",
